{
  "title": "FSI AI Gateway",
  "uid": "fsi-ai-gateway",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Requests / min",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "rate(gateway_requests_total[1m])*60", "legendFormat": "req/min" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "thresholds": { "steps": [
        {"color":"green","value":null},{"color":"yellow","value":100},{"color":"red","value":500}
      ]}}}
    },
    {
      "id": 2, "type": "stat", "title": "Cache hit rate",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "rate(gateway_cache_hits_total[5m]) / (rate(gateway_cache_hits_total[5m]) + rate(gateway_cache_misses_total[5m]))", "legendFormat": "hit rate" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [
        {"color":"red","value":null},{"color":"yellow","value":0.2},{"color":"green","value":0.4}
      ]}}}
    },
    {
      "id": 3, "type": "stat", "title": "Injection attempts",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "increase(gateway_injection_attempts_total[1h])", "legendFormat": "blocked" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [
        {"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":20}
      ]}}}
    },
    {
      "id": 4, "type": "stat", "title": "Errors",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "increase(gateway_errors_total[5m])", "legendFormat": "errors" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [
        {"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}
      ]}}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Request latency (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(gateway_request_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(gateway_request_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(gateway_request_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }}
    },
    {
      "id": 6, "type": "timeseries", "title": "Token spend by department",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(gateway_tokens_used_total{department='CX'}[5m])*60", "legendFormat": "CX" },
        { "expr": "rate(gateway_tokens_used_total{department='IT'}[5m])*60", "legendFormat": "IT" },
        { "expr": "rate(gateway_tokens_used_total{department='FINANCE'}[5m])*60", "legendFormat": "Finance" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "displayName": "tok/min" }}
    },
    {
      "id": 7, "type": "timeseries", "title": "Route decisions",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(gateway_route_decisions_total{route='CX_SIMPLE'}[5m])", "legendFormat": "CX Simple" },
        { "expr": "rate(gateway_route_decisions_total{route='CX_COMPLEX'}[5m])", "legendFormat": "CX Complex" },
        { "expr": "rate(gateway_route_decisions_total{route='CX_ESCALATE'}[5m])", "legendFormat": "CX Escalate" },
        { "expr": "rate(gateway_route_decisions_total{route='IT_SIMPLE'}[5m])", "legendFormat": "IT Simple" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Customer sentiment (compound score)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.25, rate(gateway_sentiment_score_bucket[5m]))", "legendFormat": "p25" },
        { "expr": "histogram_quantile(0.50, rate(gateway_sentiment_score_bucket[5m]))", "legendFormat": "p50 (median)" },
        { "expr": "histogram_quantile(0.75, rate(gateway_sentiment_score_bucket[5m]))", "legendFormat": "p75" }
      ],
      "fieldConfig": { "defaults": { "min": -1, "max": 1,
        "thresholds": { "steps": [
          {"color":"red","value":-1},{"color":"yellow","value":-0.5},{"color":"green","value":0}
        ]}
      }}
    },
    {
      "id": 9, "type": "bargauge", "title": "Budget fraction used by department",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "targets": [
        { "expr": "gateway_budget_fraction_used", "legendFormat": "{{department}}" }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1.5,
        "thresholds": { "steps": [
          {"color":"green","value":null},{"color":"yellow","value":0.8},
          {"color":"orange","value":1.0},{"color":"red","value":1.1}
        ]}
      }}
    },
    {
      "id": 10, "type": "timeseries", "title": "PII masking events",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "targets": [
        { "expr": "rate(gateway_pii_masked_total[5m])*60", "legendFormat": "{{department}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "displayName": "events/min" }}
    }
  ]
}
