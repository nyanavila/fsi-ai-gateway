# Copy to .env and fill in real values before running podman compose

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Models
MODEL_SMALL=claude-haiku-4-5-20251001
MODEL_LARGE=claude-sonnet-4-6

# Redis (overridden by docker-compose)
REDIS_URL=redis://localhost:6379/0

# Token budgets (daily)
BUDGET_CX_DAILY_TOKENS=5000000
BUDGET_IT_DAILY_TOKENS=1000000
BUDGET_FINANCE_DAILY_TOKENS=500000
BUDGET_DEFAULT_DAILY_TOKENS=500000

# App
APP_ENV=development
LOG_LEVEL=DEBUG
